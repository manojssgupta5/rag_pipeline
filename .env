# -------------------------------------------------------------------
# Environment
# -------------------------------------------------------------------
# local | production
APP_ENV=local

# -------------------------------------------------------------------
# Dense Embeddings
# -------------------------------------------------------------------
# ollama | openai | sentence_transformers
EMBEDDING_PROVIDER=ollama

# Ollama model
EMBEDDING_MODEL=nomic-embed-text

# nomic-embed-text = 768
EMBEDDING_DIMENSION=768

# Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# -------------------------------------------------------------------
# Sparse Embeddings
# -------------------------------------------------------------------
# hashing_tf | none
SPARSE_PROVIDER=hashing_tf

# Larger vocab reduces hash collisions
SPARSE_VOCAB_SIZE=262144

# -------------------------------------------------------------------
# Vector Store
# -------------------------------------------------------------------
# qdrant | in_memory
VECTOR_STORE_PROVIDER=qdrant

# Qdrant settings
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=support_kb
QDRANT_RECREATE=false
RRF_K=60

# -------------------------------------------------------------------
# LLM
# -------------------------------------------------------------------
# ollama | openai | none
LLM_PROVIDER=ollama

# Example:
# llama3:8b
# qwen2.5:14b
# mistral
LLM_MODEL=qwen2.5:14b

# -------------------------------------------------------------------
# Hypothetical Questions
# -------------------------------------------------------------------
ENABLE_HYPOTHETICAL_QUESTIONS=true
QUESTIONS_PER_CHUNK=3
HYPOTHETICAL_QUESTIONS_MAX_TOKENS=256

# -------------------------------------------------------------------
# Auto Metadata & Self-Query
# -------------------------------------------------------------------
ENABLE_LLM_METADATA_EXTRACTION=true
ENABLE_SELF_QUERY=true

# -------------------------------------------------------------------
# Reranker & Synthesis
# -------------------------------------------------------------------
# cross_encoder | none
RERANKER_PROVIDER=cross_encoder
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

ENABLE_ANSWER_SYNTHESIS=true

# -------------------------------------------------------------------
# Document Parser
# -------------------------------------------------------------------

# docling | plain
DOCUMENT_PARSER_PROVIDER=docling
ENABLE_OCR=true
ENABLE_TABLE_STRUCTURE=true

# Markdown export path
SAVE_MARKDOWN_TO=./parsed_documents

# -------------------------------------------------------------------
# Chunking
# -------------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
EMBED_BATCH_SIZE=64

# -------------------------------------------------------------------
# Debugging
# -------------------------------------------------------------------
DEBUG_INGESTION=true

# -------------------------------------------------------------------
# OpenAI Settings (Optional)
# Only needed if EMBEDDING_PROVIDER=openai
# or LLM_PROVIDER=openai
# -------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=

# -------------------------------------------------------------------
# Example Local Dev Setup
# -------------------------------------------------------------------
# APP_ENV=local
# VECTOR_STORE_PROVIDER=in_memory
# LLM_PROVIDER=none
# DOCUMENT_PARSER_PROVIDER=plain

# -------------------------------------------------------------------
# Example Production Setup
# -------------------------------------------------------------------
# APP_ENV=production
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# VECTOR_STORE_PROVIDER=qdrant
# LLM_PROVIDER=ollama
# DOCUMENT_PARSER_PROVIDER=docling
